{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus scraping the Prukka daemon /metrics endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "End-to-end latency (p50/p95)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, kind) (rate(prukka_e2e_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{kind}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(prukka_e2e_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{kind}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Registered sessions",
      "description": "All retained session definitions, including finished and failed sessions.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 0, "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "sum(prukka_sessions_registered)", "refId": "A" }]
    },
    {
      "title": "Sessions by runtime state",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "decimals": 0, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (state) (prukka_sessions_by_state)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Dispatcher queue",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "decimals": 0, "min": 0 }, "overrides": [] },
      "targets": [
        { "expr": "sum(prukka_dispatch_queue_depth)", "legendFormat": "waiting", "refId": "A" },
        { "expr": "sum(prukka_dispatch_queue_capacity)", "legendFormat": "capacity", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["prukka"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Prukka",
  "uid": "prukka-main",
  "version": 2
}
