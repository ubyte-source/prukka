# Committed artifacts, marked so diffs collapse and language stats stay
# honest. Each tree has a CI gate proving it matches its source:
# internal/gen/ against proto/ (make gen) and internal/webui/dist/ against
# web/ (make web).
internal/gen/** linguist-generated=true
internal/webui/dist/** linguist-generated=true

# Vendored Google API protos (see proto/google/api/README.md).
proto/google/** linguist-vendored=true
