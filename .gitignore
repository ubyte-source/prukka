# Build outputs.
/bin/
/dist/

# Driver payloads staged by the release workflow (embedded via the
# bundleddrivers build tag).
/internal/devices/assets/

# Repo-local pinned tools (installed by `make tools`).
/.tools/
/hack/tools/

# Test and coverage artifacts.
*.test
coverage.out

# Local development state (created by `make dev` / demo scripts).
/tmp/

# Frontend toolchain (build-time only; see internal/webui/web.go).
node_modules/
web/test-results/
web/playwright-report/

# Editor noise.
.DS_Store
drivers/macos/webcam/build/
drivers/macos/microphone/build/
drivers/macos/audio/build/
drivers/macos/capture/build/

# Tool binaries built at the repo root by `go build ./hack/cmd/...`.
/engine-catalog
/release-sbom
/deterministic-tar
/protocol-engine
drivers/windows/webcam/build/
drivers/windows/*/x64/
drivers/windows/*/*.sys
drivers/windows/*/*.obj
drivers/linux/*/*.ko
drivers/linux/*/*.o
drivers/linux/*/*.mod*
drivers/linux/*/.*.cmd
drivers/linux/*/modules.order
drivers/linux/*/Module.symvers
/prukka
/engine/engine
/engine/engine.exe

# Go fuzzing corpus is machine-generated.
testdata/fuzz/
